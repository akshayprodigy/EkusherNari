# EmailJS credentials — sign up at https://www.emailjs.com/ and fill in below.
# Do NOT commit the real .env file to git.

# From EmailJS dashboard → Email Services
VITE_EMAILJS_SERVICE_ID=

# From EmailJS dashboard → Account → General → Public Key
VITE_EMAILJS_PUBLIC_KEY=

# From EmailJS dashboard → Email Templates (create two templates)
# Contact Us form
VITE_EMAILJS_CONTACT_TEMPLATE_ID=
# Product Enquiry form (Gallery modal)
VITE_EMAILJS_ENQUIRY_TEMPLATE_ID=
