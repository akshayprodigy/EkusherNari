# ==============================================================================
# Ekusher Naree — Apache config for document root (public_html)
# This file is generated by Vite from public/.htaccess into dist/.htaccess
# and rsynced to /home2/ekushpp6/public_html/.htaccess on deploy.
# ==============================================================================

# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
    AddHandler application/x-httpd-ea-php82___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# ------------------------------------------------------------------------------
# Block dotfiles (including .env and backups) from being served.
# ------------------------------------------------------------------------------
<FilesMatch "^\.(?!well-known)">
    Require all denied
</FilesMatch>

# ------------------------------------------------------------------------------
# Force HTTPS — 301-redirect any plain-HTTP request to the HTTPS equivalent.
# Uses %{HTTPS} which Apache sets to "on" when the request came in via TLS.
# Kept as a separate rewrite block so it fires before SPA fallback.
# ------------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# ------------------------------------------------------------------------------
# SPA fallback — React Router owns client-side routing. Any request that does
# NOT match a real file or directory falls back to index.html.
# PHP files under /api/ ARE real files, so the condition below skips them.
# ------------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Don't rewrite real files or directories (images, PHP endpoints, .well-known)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Leave the subdomain document roots alone
    RewriteCond %{HTTP_HOST} ^(emagazine|oam)\.ekushernaree\.com$ [NC]
    RewriteRule ^ - [L]

    # Everything else → SPA entry
    RewriteRule ^ /index.html [L]
</IfModule>

# ------------------------------------------------------------------------------
# Compression
# ------------------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ------------------------------------------------------------------------------
# Cache headers — JS/CSS are content-hashed by Vite, so cache them for a year.
# HTML is always revalidated so new deploys are picked up immediately.
# ------------------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    ExpiresByType text/html                 "access plus 0 seconds"

    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType application/x-javascript  "access plus 1 year"

    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(?:html|htm)$">
        Header set Cache-Control "no-cache, must-revalidate, max-age=0"
    </FilesMatch>

    <FilesMatch "\.(?:js|css|woff2?|png|jpg|jpeg|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# ------------------------------------------------------------------------------
# Security headers
# ------------------------------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ------------------------------------------------------------------------------
# Default document
# ------------------------------------------------------------------------------
DirectoryIndex index.html index.php
